OPENROUTER_API_KEY=your_openrouter_api_key_here

AGENTMAIL_API_KEY=your_agentmail_api_key_here

AGENTMAIL_WEBHOOK_SECRET=your_webhook_secret_here

INBOX_ID=your_inbox_id@agentmail.to

DATABASE_URL=postgresql://postgres:password@localhost:5433/database

# Hindsight — choose one of: local or cloud
HINDSIGHT_API_URL=http://localhost:8888        # local self-hosted
# HINDSIGHT_API_URL=https://api.hindsight.vectorize.io  # Hindsight Cloud
HINDSIGHT_API_KEY=                             # required for Cloud; leave empty for local

# Model Configuration for Prompt Caching
# Primary model (MiniMax recommended for auto-caching)
PARSER_MODEL_ID=minimax/minimax-m2.5
TRIAGE_MODEL_ID=minimax/minimax-m2.5
REPLY_MODEL_ID=minimax/minimax-m2.5

# Enable explicit caching (only for Anthropic models)
# Set to true when using anthropic/* models, false for minimax/* (auto-cached)
PARSER_ENABLE_CACHING=false
TRIAGE_ENABLE_CACHING=false
REPLY_ENABLE_CACHING=false

# Fallback models (optional, max 3)
PARSER_FALLBACK_MODELS=anthropic/claude-haiku-4.5,anthropic/claude-sonnet-4.6
TRIAGE_FALLBACK_MODELS=anthropic/claude-haiku-4.5,anthropic/claude-sonnet-4.6
REPLY_FALLBACK_MODELS=anthropic/claude-haiku-4.5,anthropic/claude-sonnet-4.6


BINDU_DEPLOYMENT_URL=http://localhost:3773